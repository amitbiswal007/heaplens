# Rust source and build artifacts (binary is in bin/)
hprof-analyzer/
Cargo.lock

# TypeScript source (compiled JS is in out/)
src/
tsconfig.json
.eslintrc.json

# Docusaurus site
docs-site/

# Dev tooling
.vscode/
.claude/
scripts/

# Project docs (not needed in extension)
CLAUDE.md
CHANGELOG.md
CONTRIBUTING.md

# Screenshots & media (served from GitHub, not needed in VSIX)
media/screenshots/

# JVM agent source (users build separately)
jvm-agent/

# Source SVG (PNG is used by the extension)
icon.svg

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo

# Test and sample files
*.hprof
**/*.hprof

# Git
.git/
.gitignore

# Strip source maps and browser bundles from production deps (saves ~90MB)
**/*.js.map
**/browser/
**/dist-esm/

# Node dev dependencies are excluded by vsce automatically
# (do NOT add node_modules/ here — it would also strip production deps like @vscode/extension-telemetry)
