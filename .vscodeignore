# TypeScript source (compiled JS is in out/)
src/
tsconfig.json
.eslintrc.json

# Docusaurus site
docs-site/

# Dev tooling
.vscode/
.claude/
scripts/

# Project docs (not needed in extension)
CLAUDE.md
*.md
!package.json

# Source SVG (PNG is used by the extension)
icon.svg

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo

# Test and sample files
*.hprof
**/*.hprof

# Git
.git/
.gitignore

# Node dev dependencies are excluded by vsce automatically
# but be explicit about node_modules just in case
node_modules/
