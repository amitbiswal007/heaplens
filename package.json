{
  "name": "heaplens",
  "displayName": "HeapLens",
  "description": "LLM-powered Java heap dump analyzer with interactive visualizations",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Debuggers",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:heaplens.hprofEditor",
    "onCommand:heaplens.analyzeFile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "heaplens.analyzeFile",
        "title": "HeapLens: Analyze HPROF File"
      },
      {
        "command": "heaplens.exportJson",
        "title": "HeapLens: Export Analysis to JSON"
      }
    ],
    "customEditors": [
      {
        "viewType": "heaplens.hprofEditor",
        "displayName": "HeapLens HPROF Viewer",
        "selector": [
          {
            "filenamePattern": "*.hprof"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {}
}
